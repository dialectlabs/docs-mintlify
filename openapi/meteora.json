              "default": "BGm1tav58oGcsQJehL9WXBFXF7D27vZsKefj4xJKD5Y"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "required": true,
            "style": "deepObject",
            "explode": true,
            "schema": {
              "type": "number",
              "minimum": 0,
              "description": "The amount of tokenX to add",
              "default": 0.01
            }
