      "post": {
        "operationId": "meteora.v0.dlmm.addLiquidityToDlmm",
        "summary": "Add Liquidity",
        "description": "Add liquidity to a DLMM pool",
        "tags": [
          "DLMM"
        ],
        "parameters": [
          {
            "name": "dlmmPool",
            "in": "path",
            "required": true,
